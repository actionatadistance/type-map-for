{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "paths": {
      "@type-map-for/core":          ["./packages/core/src/index.ts"],
      "@type-map-for/bigquery":      ["./packages/bigquery/src/index.ts"],
      "@type-map-for/postgres":      ["./packages/postgres/src/index.ts"],
      "@type-map-for/typesense":     ["./packages/typesense/src/index.ts"],
      "@type-map-for/elasticsearch": ["./packages/elasticsearch/src/index.ts"],
      "@type-map-for/avro":          ["./packages/avro/src/index.ts"],
      "@type-map-for/dynamodb":      ["./packages/dynamodb/src/index.ts"],
      "@type-map-for/clickhouse":    ["./packages/clickhouse/src/index.ts"],
      "@type-map-for/mongodb":       ["./packages/mongodb/src/index.ts"]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/test/**/*.ts",
    "test/fixtures/**/*.ts"
  ]
}
